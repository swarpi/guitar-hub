{
	"name": "music-hub",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"pages:build": "npx @cloudflare/next-on-pages",
		"start": "next start",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"pages:dev": "wrangler pages dev",
		"seed": "tsx src/db/seed.ts",
		"dev:ai": "tsx scripts/ai-proxy.ts",
		"dev:mcp": "tsx --tsconfig tsconfig.mcp.json scripts/mcp-sheet-server.ts",
		"dev:all": "tsx scripts/ai-proxy.ts & pnpm dev"
	},
	"dependencies": {
		"abcjs": "^6.6.3",
		"drizzle-orm": "^0.45.2",
		"nanoid": "^5.1.11",
		"next": "16.2.9",
		"react": "19.2.4",
		"react-dom": "19.2.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@cloudflare/next-on-pages": "^1.13.16",
		"@cloudflare/workers-types": "^4.20260613.1",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/postcss": "^4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/jsdom": "^28.0.3",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^6.0.2",
		"better-sqlite3": "^12.10.1",
		"drizzle-kit": "^0.31.10",
		"jsdom": "^29.1.1",
		"tailwindcss": "^4",
		"tsx": "^4.22.4",
		"typescript": "^5",
		"vitest": "^4.1.8",
		"wrangler": "^4.100.0",
		"zod": "^4.4.3"
	}
}
