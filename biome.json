{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["src/**", "*.ts", "*.json", "*.css"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended"
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"cssModules": true,
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["src/lib/store.ts"],
			"linter": {
				"rules": {
					"a11y": {
						"noStaticElementInteractions": "off",
						"useKeyWithClickEvents": "off",
						"useButtonType": "off",
						"noLabelWithoutControl": "off",
						"useSemanticElements": "off"
					},
					"suspicious": {
						"noAssignInExpressions": "off",
						"noArrayIndexKey": "off"
					}
				}
			}
		}
	],
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
